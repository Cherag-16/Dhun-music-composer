# Dhun AI Environment Variables Template
# Copy this file to .env.local and fill in your values

# ============================================
# Supabase Configuration
# ============================================
# Get these from: https://app.supabase.com → Settings → API Keys

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# Groq AI Configuration
# ============================================
# Get this from: https://console.groq.com → API Keys
# Used for mood detection, category prediction, and melody analysis

GROQ_API_KEY=your_groq_api_key_here

# ============================================
# Optional: Additional Integrations
# ============================================
# Uncomment and add these if needed in future phases

# NEXT_PUBLIC_GA_ID=                    # Google Analytics
# VERCEL_ANALYTICS_ID=                  # Vercel Analytics
# DATABASE_URL=                         # Alternative DB connection

# ============================================
# Development Settings
# ============================================
# NODE_ENV is automatically set by Next.js
# NODE_ENV=development

# ============================================
# Important Notes
# ============================================
# 1. Never commit .env.local to version control
# 2. Keep API keys secret and secure
# 3. Use different keys for production
# 4. Rotate keys periodically
# 5. Set environment variables on your hosting platform (Vercel, etc.)

# ============================================
# Setup Instructions
# ============================================
# 
# 1. Get Supabase Keys:
#    - Go to https://app.supabase.com
#    - Select your project
#    - Settings → API → Copy the keys
#
# 2. Get Groq API Key:
#    - Go to https://console.groq.com
#    - Create API key
#    - Copy it here
#
# 3. Save as .env.local:
#    cp .env.example .env.local
#    Edit with your keys
#
# 4. Start development:
#    npm run dev
